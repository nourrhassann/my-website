ann/my-website/src/hooks/withRouter.js",[],[],"/Users/shahhdhassann/my-website/src/hooks/AnimatedCursor.js",[],["68"],"/Users/shahhdhassann/my-website/src/header/index.js",[],[],"/Users/shahhdhassann/my-website/src/content_option.js",[],[],"/Users/shahhdhassann/my-website/src/pages/home/index.js",[],[],"/Users/shahhdhassann/my-website/src/pages/portfolio/index.js",[],[],"/Users/shahhdhassann/my-website/src/pages/contact/index.js",[],[],"/Users/shahhdhassann/my-website/src/pages/about/index.js",["69"],[],"import React from \"react\";\nimport \"./style.css\";\nimport { Helmet, HelmetProvider } from \"react-helmet-async\";\nimport { Container, Row, Col } from \"react-bootstrap\";\nimport {\n  dataabout,\n  meta,\n  worktimeline,\n  skills,\n  services,\n} from \"../../content_option\";\n\nexport const About = () => {\n  return (\n    <HelmetProvider>\n      <Container className=\"About-header\">\n        <Helmet>\n          <meta charSet=\"utf-8\" />\n          <title> About | {meta.title}</title>\n          <meta name=\"description\" content={meta.description} />\n        </Helmet>\n        <Row className=\"mb-5 mt-3 pt-md-3\">\n          <Col lg=\"8\">\n            <h1 className=\"display-4 mb-4\">About me</h1>\n            <hr className=\"t_border my-4 ml-0 text-left\" />\n          </Col>\n        </Row>\n        <Row className=\"sec_sp\">\n          <Col lg=\"5\">\n            <h3 className=\"color_sec py-4\">{dataabout.title}</h3>\n          </Col>\n          <Col lg=\"7\" className=\"d-flex align-items-center\">\n            <div>\n              <p>{dataabout.aboutme}</p>\n            </div>\n          </Col>\n        </Row>\n        <Row className=\" sec_sp\">\n          <Col lg=\"5\">\n            <h3 className=\"color_sec py-4\">Work Timline</h3>\n          </Col>\n          <Col lg=\"7\">\n            <table className=\"table caption-top\">\n              <tbody>\n                {worktimeline.map((data, i) => {\n                  return (\n                    <tr key={i}>\n                      <th scope=\"row\">{data.jobtitle}</th>\n                      <td>{data.where}</td>\n                      <td>{data.date}</td>\n                    </tr>\n                  );\n                })}\n              </tbody>\n            </table>\n          </Col>\n        </Row>\n        <Row className=\"sec_sp\">\n          <Col lg=\"5\">\n            <h3 className=\"color_sec py-4\">Skills</h3>\n          </Col>\n          <Col lg=\"7\">\n            {skills.map((data, i) => (\n              <div key={i} className=\"skill-item mb-3\">\n                <h5 className=\"skill-category\">{data.category}:</h5>\n                <p className=\"skill-tools\">{data.tools}</p>\n                <div className=\"progress\">\n                  <div className=\"progress-value\">{data.value || \"\"}%</div>\n                </div>\n              </div>\n            ))}\n          </Col>\n        </Row>\n      </Container>\n    </HelmetProvider>\n  );\n};\n","/Users/shahhdhassann/my-website/src/components/socialicons/index.js",[],[],"/Users/shahhdhassann/my-website/src/components/themetoggle/index.js",[],[],{"ruleId":"70","severity":1,"message":"71","line":150,"column":7,"nodeType":"72","endLine":150,"endColumn":19,"suggestions":"73","suppressions":"74"},{"ruleId":"75","severity":1,"message":"76","line":10,"column":3,"nodeType":"77","messageId":"78","endLine":10,"endColumn":11},"react-hooks/exhaustive-deps","React Hook useCallback has missing dependencies: 'coords' and 'trailingSpeed'. Either include them or remove the dependency array.","ArrayExpression",["79"],["80"],"no-unused-vars","'services' is defined but never used.","Identifier","unusedVar",{"desc":"81","fix":"82"},{"kind":"83","justification":"84"},"Update the dependencies array to be: [coords, trailingSpeed]",{"range":"85","text":"86"},"directive","",[4202,4214],"[coords, trailingSpeed]"]